generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum VehicleSegment {
  HATCHBACK
  SEDAN
  SUV
  MPV
  PICKUP
}

enum ItemType {
  PART
  PACKAGE
}

enum UserRole {
  ADMIN
}

enum QuoteType {
  PART
  PACKAGE
}

model PaintItem {
  id          String         @id @default(cuid())
  code        String         @unique
  name        String
  type        ItemType
  description String?
  active      Boolean        @default(true)
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  prices      SegmentPrice[]
  quoteLines  QuoteLine[]

  @@index([type, active, sortOrder])
}

model SegmentPrice {
  id      String         @id @default(cuid())
  itemId  String
  segment VehicleSegment
  price   Int
  item    PaintItem      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, segment])
  @@index([segment])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Quote {
  id          String         @id @default(cuid())
  segment     VehicleSegment
  quoteType   QuoteType
  totalAmount Int
  notes       String?
  createdAt   DateTime       @default(now())
  lines       QuoteLine[]

  @@index([segment, quoteType, createdAt])
}

model QuoteLine {
  id                String     @id @default(cuid())
  quoteId           String
  itemId            String?
  itemNameSnapshot  String
  unitPriceSnapshot Int
  quantity          Int        @default(1)
  lineTotal         Int
  quote             Quote      @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  item              PaintItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([quoteId])
}
